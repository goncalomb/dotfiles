#!/bin/bash

# /// dotfiles
# description = "Set the modified date of the files on a git repository to the last commit date that changed the files."
# author = "goncalomb"
# year = "2017"
# tags = ["unknown"]
# ///

git rev-parse HEAD > /dev/null
if [ $? -ne 0 ]; then
	exit 1
fi

# TODO: for some reason `git ls-tree -r -t HEAD` only works on the top level
#       just cd to the top level for now
cd "`git rev-parse --show-toplevel`"

git ls-tree -r -t HEAD --name-only | while IFS= read -r f; do
	t=$(git log -n 1 --format="%ct" -- "$f")
	if [ -n "$t" ]; then
		echo "$t" "$f"
		touch -m -d "@$t" "$f"
	fi
done
