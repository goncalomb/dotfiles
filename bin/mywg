#!/usr/bin/env bash

# /// dotfiles
# description = "Configures WireGuard from a well-known configuration file."
# author = "goncalomb"
# year = "2023"
# tags = ["unknown"]
# ///

set -euo pipefail
cd -- "$(dirname -- "$0")"

cd ../tmp

sudo -v

# using $PWD to show full path on error messages
{
    wg-quick up "$PWD/$HOSTNAME.conf" && sudo wg show
} || {
    wg-quick down "$PWD/$HOSTNAME.conf"
}
