#!/usr/bin/env bash

# /// dotfiles
# description = "Run Ansible playbooks (`playbook.yaml` + `playbook-*.yaml`) with optional `inventory.yaml`, after installing `requirements.yaml`."
# author = "goncalomb"
# year = "2025-2026"
# tags = ["stable"]
# ///

set -euo pipefail
shopt -s nullglob

ARGUMENTS=()
PLAYBOOKS=()
DD=
for ARG in "$@"; do
    [ "$ARG" == "--" ] && DD=1 && continue
    [ -z "$DD" ] && ARGUMENTS+=("$ARG") || PLAYBOOKS+=("$ARG")
done

[ ${#PLAYBOOKS[@]} -eq 0 ] && PLAYBOOKS+=(playbook[.]yaml playbook-*.yaml)
[ ${#PLAYBOOKS[@]} -eq 0 ] && PLAYBOOKS+=(playbook.yaml)

if [ -f requirements.yaml ]; then
    echo "requirements:"
    echo "  requirements.yaml"
fi
if [ -f inventory.yaml ]; then
    echo "inventory:"
    echo "  inventory.yaml"
    ARGUMENTS+=("-i" "inventory.yaml")
fi
echo "playbooks:"
for PB in "${PLAYBOOKS[@]}"; do
    echo "  $PB"
done

export ANSIBLE_INVENTORY_UNPARSED_WARNING=False
export ANSIBLE_LOCALHOST_WARNING=False

[ -f requirements.yaml ] && ansible-galaxy install -r requirements.yaml
exec ansible-playbook "${ARGUMENTS[@]}" -- "${PLAYBOOKS[@]}"
