#!/usr/bin/env bash

# /// dotfiles
# description = "Run Ansible playbooks (`playbook.yaml` + `playbook-*.yaml`) with `inventory.yaml`, also installs `requirements.yaml`."
# author = "goncalomb"
# year = "2025"
# tags = ["stable"]
# ///

set -euo pipefail
shopt -s nullglob

ARGUMENTS=()
PLAYBOOKS=()
DD=
for ARG in "$@"; do
    [ "$ARG" == "--" ] && DD=1 && continue
    [ -z "$DD" ] && ARGUMENTS+=("$ARG") || PLAYBOOKS+=("$ARG")
done

[ ${#PLAYBOOKS[@]} -eq 0 ] && PLAYBOOKS+=(playbook[.]yaml playbook-*.yaml)
[ ${#PLAYBOOKS[@]} -eq 0 ] && PLAYBOOKS+=(playbook.yaml)

if [ -f requirements.yaml ]; then
    echo "requirements:"
    echo "  requirements.yaml"
fi
echo "inventory:"
echo "  inventory.yaml"
echo "playbooks:"
for PB in "${PLAYBOOKS[@]}"; do
    echo "  $PB"
done

[ -f requirements.yaml ] && ansible-galaxy install -r requirements.yaml
ansible-playbook -i inventory.yaml "${ARGUMENTS[@]}" -- "${PLAYBOOKS[@]}"
